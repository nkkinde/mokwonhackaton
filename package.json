{
  "name": "chat-backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "dev:worker": "tsx src/jobs/index.ts",
    "build": "tsc -p .",
    "start": "node dist/server.js",
    "start:worker": "node dist/jobs/index.js",
    "prisma:dev": "prisma migrate dev --name init && prisma generate",
    "lint": "eslint . || true",
    "test": "echo \"(add tests)\" && exit 0"
  },
  "dependencies": {
